  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Effects can be inflicted by some attacks. They will appear next to member's
    health. You can hover over effect while your character is on turn to reveal specific
    info. \n\nEffects:\n  DoT (Damage over Time) - member takes damage at the end
    of a round.\n  Protection - member takes less damage, DoT ignores it.\n  Stun
    - Skips member's turn, triggers on turn rather than at the end of a round.\n 
    Stun Resistance - member gets this after being stunned to prevent infinite stunning.\n 
    Taunt - makes opposite team target this member if they can, multi target attacks
    still work."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ea3febd2a652e944cbc6ba9ae7d35fed, type: 2}
  m_sharedMaterial: {fileID: 2390640544149086462, guid: ea3febd2a652e944cbc6ba9ae7d35fed, type: 2}
