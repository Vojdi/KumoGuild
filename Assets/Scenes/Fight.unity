    m_PersistentCalls:
      m_Calls: []
  m_text: 'Skill info shows when you hover over any skill, showing you what it does.
    First row is the skill name, second row is the skill type and target type. You
    can either have attack/support skill and single/multi targeting. The third row
    shows which positions does the skill target. If it has multi, it will target
    all of the full squares. The last part are stats, it shows what will happen to
    every target. This example shows they  will recieve 4 - 6 damage and they will
    be stunned for 1 turn.

'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: ea3febd2a652e944cbc6ba9ae7d35fed, type: 2}
